{
  "expo": {
    "name": "Bus",
    "slug": "bus",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0e0e10"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yourcollege.bustracking",
      "googleServicesFile": "./GoogleService-Info.plist",
      "config": {
        "googleMapsApiKey": "AIzaSyAvCmL9l8PXps8b7wWCmavTuwjeoLpkfrs"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Allow Bus to access your location while driving so students can see the bus on the map."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0e0e10"
      },
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAvCmL9l8PXps8b7wWCmavTuwjeoLpkfrs"
        }
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.yourcollege.bustracking",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-asset",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Bus to access your location while driving so students can see the bus on the map."
        }
      ],
      "@react-native-community/datetimepicker",
      "@react-native-firebase/app",
      [
        "expo-build-properties",
        {
          "ios": { "useFrameworks": "static" }
        }
      ]
    ]
  }
}
